# ============================================================
#  DOJX Backend — Variables de entorno
#  Copia este archivo como .env y rellena con tus valores
#  NUNCA subas el .env a git — ya está en .gitignore
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Base de datos PostgreSQL ──────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/dojx

# ── JWT ───────────────────────────────────────────────────────
# Genera una clave segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_muy_larga_y_aleatoria
JWT_EXPIRES_IN=7d

# ── Admin ─────────────────────────────────────────────────────
# El usuario que inicie sesión con este email recibirá rol=admin en el JWT
ADMIN_EMAIL=tu@correo.com

# ── Frontend (CORS) ───────────────────────────────────────────
# URL donde corre tu frontend. En desarrollo es el Live Server de VS Code
FRONTEND_URL=http://localhost:5500

# ── Cloudinary (subida de imágenes) — opcional por ahora ─────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Wompi (pagos Colombia) — opcional por ahora ──────────────
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_WEBHOOK_SECRET=
